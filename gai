#!/usr/bin/env bash
# gai — AI git commit using local Ollama (qwen2.5-coder:1.5b)
# Usage: gai [--all] [--dry-run] [--version] [--logs]
#
#   Default (no flags): commit STAGED files one by one
#   --all              : commit ALL dirty files one by one
#   --dry-run          : print messages, don't commit
#   --version          : print installed gai-tools version
#   --logs             : show last 24 h of activity

set -euo pipefail

MODEL="${GAI_MODEL:-qwen2.5-coder:1.5b}"
OLLAMA_URL="http://localhost:11434/api/generate"
DRY_RUN=false
MODE="staged"
LOG_DIR="${GAI_LOG_DIR:-$HOME/.gai/logs}"

_prune_logs() {
  mkdir -p "$LOG_DIR"
  find "$LOG_DIR" -name "*.log" -mmin +1440 -delete 2>/dev/null || true
}

# ── arrow-key selection menu ──────────────────────────────────────────────────
# Sets global _MENU_RESULT to the 0-based index of the chosen item.

_gai_select_menu() {
  local _idx=0 _count=$# _key _esc _i _opt
  tput civis 2>/dev/null || true
  _i=0
  for _opt in "$@"; do
    if [[ "$_i" -eq "$_idx" ]]; then
      printf "  \033[7m▶ %s\033[0m\n" "$_opt"
    else
      printf "    %s\n" "$_opt"
    fi
    _i=$(( _i + 1 ))
  done
  while true; do
    IFS= read -rsn1 _key
    if [[ "$_key" == $'\x1b' ]]; then
      IFS= read -rsn2 -t 0.1 _esc || true
      case "$_esc" in
        '[A') if [[ "$_idx" -gt 0 ]]; then _idx=$(( _idx - 1 )); fi ;;
        '[B') if [[ "$_idx" -lt $(( _count - 1 )) ]]; then _idx=$(( _idx + 1 )); fi ;;
      esac
    elif [[ "$_key" == '' || "$_key" == $'\r' ]]; then
      break
    fi
    printf "\033[%dA" "$_count"
    _i=0
    for _opt in "$@"; do
      if [[ "$_i" -eq "$_idx" ]]; then
        printf "  \033[7m▶ %s\033[0m\033[K\n" "$_opt"
      else
        printf "    %s\033[K\n" "$_opt"
      fi
      _i=$(( _i + 1 ))
    done
  done
  tput cnorm 2>/dev/null || true
  _MENU_RESULT=$_idx
}

# ── issue subcommand ──────────────────────────────────────────────────────────

if [[ "${1:-}" == "issue" ]]; then
  _issue_url="${2:-}"

  if [[ -z "$_issue_url" ]]; then
    echo "Usage: gai issue <github-issue-url>" >&2
    exit 1
  fi

  _issue_num=$(echo "$_issue_url" | grep -oE '/issues/[0-9]+' | grep -oE '[0-9]+')
  _issue_repo=$(echo "$_issue_url" | grep -oE 'github\.com/[^/]+/[^/]+' | sed 's|github\.com/||')

  if [[ -z "$_issue_num" || -z "$_issue_repo" ]]; then
    echo "error: invalid GitHub issue URL: $_issue_url" >&2
    echo "  Expected: https://github.com/owner/repo/issues/123" >&2
    exit 1
  fi

  if ! command -v gh > /dev/null 2>&1; then
    echo "error: gh CLI not installed." >&2
    echo "  Install: brew install gh && gh auth login" >&2
    exit 1
  fi

  if ! gh auth status > /dev/null 2>&1; then
    echo "error: gh CLI not authenticated. Run: gh auth login" >&2
    exit 1
  fi

  echo "→ Fetching open PRs for ${_issue_repo}…"

  _pr_list=()
  while IFS= read -r _line; do
    [[ -n "$_line" ]] && _pr_list+=("$_line")
  done < <(gh pr list --repo "$_issue_repo" --state open --json number,title --jq '.[] | "\(.number)|\(.title)"')

  if [[ ${#_pr_list[@]} -eq 0 ]]; then
    echo "No open PRs in $_issue_repo." >&2
    exit 1
  fi

  _pr_num=""
  if [[ ${#_pr_list[@]} -eq 1 ]]; then
    _pr_num=$(echo "${_pr_list[0]}" | cut -d'|' -f1)
    _pr_title=$(echo "${_pr_list[0]}" | cut -d'|' -f2)
    echo "→ Auto-selecting PR #$_pr_num: $_pr_title"
  else
    echo ""
    echo "Multiple open PRs — select one:"
    _pr_options=()
    for _entry in "${_pr_list[@]}"; do
      _n=$(echo "$_entry" | cut -d'|' -f1)
      _t=$(echo "$_entry" | cut -d'|' -f2)
      _pr_options+=("#$_n: $_t")
    done
    _gai_select_menu "${_pr_options[@]}"
    _idx=$_MENU_RESULT
    _pr_num=$(echo "${_pr_list[$_idx]}" | cut -d'|' -f1)
    _pr_title=$(echo "${_pr_list[$_idx]}" | cut -d'|' -f2)
  fi

  _pr_body=$(gh pr view "$_pr_num" --repo "$_issue_repo" --json body --jq '.body')

  if echo "$_pr_body" | grep -qE "#${_issue_num}([^0-9]|$)"; then
    echo "Issue #$_issue_num already referenced in PR #$_pr_num."
    exit 0
  fi

  gh pr edit "$_pr_num" --repo "$_issue_repo" --body "${_pr_body}
Closes #${_issue_num}"

  echo "✓ Added \"Closes #${_issue_num}\" to PR #${_pr_num}"
  exit 0
fi

# ── flag parsing ──────────────────────────────────────────────────────────────

for arg in "$@"; do
  case "$arg" in
    --dry-run|-n) DRY_RUN=true ;;
    --all)        MODE="all" ;;
    --version|-v)
      echo "gai v$(cat "$HOME/.gai/version" 2>/dev/null || echo "unknown")"
      exit 0
      ;;
    --logs)
      _prune_logs
      _lf=()
      while IFS= read -r f; do
        [[ -n "$f" ]] && _lf+=("$f")
      done < <(find "$LOG_DIR" -name "*.log" -mmin -1440 2>/dev/null | sort)
      if [[ ${#_lf[@]} -eq 0 ]]; then
        echo "No gai activity in the last 24 h."
      else
        cat "${_lf[@]}"
      fi
      exit 0
      ;;
    update)
      echo "→ Updating gai-tools from GitHub…"
      _old_ver=$(cat "$HOME/.gai/version" 2>/dev/null || echo "unknown")
      TMP=$(mktemp -d)
      _release_json=$(curl -fsSL https://api.github.com/repos/Navibyte-Innovations-Pvt-Ltd/gai-tools/releases/latest)
      _new_ver=$(echo "$_release_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('tag_name','').lstrip('v'))" 2>/dev/null || echo "")
      TARBALL=$(echo "$_release_json" | python3 -c "import sys,json; assets=json.load(sys.stdin)['assets']; print(next(a['name'] for a in assets if a['name'].endswith('.tar.gz')))")
      curl -fsSL "https://github.com/Navibyte-Innovations-Pvt-Ltd/gai-tools/releases/latest/download/${TARBALL}" \
        | tar -xz -C "$TMP"
      bash "$TMP/install.sh"
      rm -rf "$TMP"
      if [[ -n "$_new_ver" && "$_old_ver" != "$_new_ver" ]]; then
        echo "✓ gai-tools updated  v${_old_ver} → v${_new_ver}"
      else
        echo "✓ gai-tools updated  v${_new_ver} (already latest)"
      fi
      exit 0
      ;;
    pr)
      _gai_pr=true
      ;;
    pause)
      mkdir -p "$HOME/.gai"
      touch "$HOME/.gai/paused"
      echo "⏸  Auto-commit paused. 'gai pr' and 'gai issue' still work."
      echo "   Resume with: gai resume"
      exit 0
      ;;
    resume)
      rm -f "$HOME/.gai/paused"
      echo "▶  Auto-commit resumed."
      exit 0
      ;;
    remove|uninstall)
      echo "This will remove gai/gai-watch, stop all watchers, and remove the ~/.zshrc hook."
      read -rp "Continue? [y/N] " _confirm
      if [[ "$_confirm" != "y" && "$_confirm" != "Y" ]]; then
        echo "Aborted."
        exit 0
      fi

      pkill -f gai-watch 2>/dev/null || true
      rm -f /tmp/gai-watch-*.pid

      if grep -q "gai-tools:" "$HOME/.zshrc" 2>/dev/null; then
        sed -i '' '/# gai-tools: auto-start/,/# end gai-tools/d' "$HOME/.zshrc"
        echo "✓ Removed hook from ~/.zshrc"
      fi

      rm -f "$HOME/.local/bin/gai" "$HOME/.local/bin/gai-watch"
      echo "✓ Removed gai and gai-watch from ~/.local/bin"

      echo ""
      echo "gai-tools uninstalled. Ollama and fswatch were left in place."
      echo "  To remove them: brew uninstall ollama fswatch"
      echo "  Reload shell: source ~/.zshrc"
      exit 0
      ;;
    --help|-h)
      echo "Usage: gai [--all] [--dry-run] [--version] [--logs] [update] [pr] [issue <url>] [pause] [resume] [remove]"
      echo "  Default      : commit staged files one by one (AI message per file)"
      echo "  --all        : commit all dirty files instead of staged"
      echo "  --dry-run    : show messages without committing"
      echo "  --version    : print installed gai-tools version"
      echo "  --logs       : show last 24 h of activity (\$GAI_LOG_DIR)"
      echo "  update       : pull latest version from GitHub"
      echo "  pr           : create a GitHub PR from current branch (requires gh CLI)"
      echo "  issue <url>  : attach a GitHub issue to an open PR (auto if one PR, select if many)"
      echo "  pause        : stop auto-commit (gai pr / gai issue keep working)"
      echo "  resume       : re-enable auto-commit after 'gai pause'"
      echo "  remove       : uninstall gai/gai-watch (alias: uninstall)"
      echo ""
      echo "Model: \$GAI_MODEL (default: $MODEL)"
      echo "Requires: ollama running + model pulled"
      echo "  brew install ollama && ollama pull $MODEL"
      exit 0
      ;;
  esac
done

# ── pr subcommand ─────────────────────────────────────────────────────────────

if [[ "${_gai_pr:-false}" == "true" ]]; then
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "error: not inside a git repository" >&2
    exit 1
  fi

  if ! command -v gh > /dev/null 2>&1; then
    echo "error: gh CLI not installed." >&2
    echo "  Install: brew install gh && gh auth login" >&2
    exit 1
  fi

  if ! gh auth status > /dev/null 2>&1; then
    echo "error: gh CLI not authenticated." >&2
    echo "  Run: gh auth login" >&2
    exit 1
  fi

  CURRENT_BRANCH=$(git branch --show-current)
  BASE_BRANCH=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || echo "main")

  if [[ "$CURRENT_BRANCH" == "$BASE_BRANCH" || "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "master" ]]; then
    echo "error: on branch '$CURRENT_BRANCH' — switch to a feature branch first." >&2
    exit 1
  fi

  git fetch origin "$BASE_BRANCH" --quiet 2>/dev/null || true
  PR_COMMITS=$(git log "origin/$BASE_BRANCH"..HEAD --oneline 2>/dev/null)
  if [[ -z "$PR_COMMITS" ]]; then
    echo "error: no commits ahead of 'origin/$BASE_BRANCH' — nothing to PR." >&2
    exit 1
  fi

  if ! curl -s --connect-timeout 2 "http://localhost:11434" > /dev/null 2>&1; then
    echo "error: Ollama not running." >&2
    echo "  Start:   ollama serve" >&2
    echo "  Install: brew install ollama && ollama pull $MODEL" >&2
    exit 1
  fi

  PR_DIFF_STAT=$(git diff "origin/$BASE_BRANCH"...HEAD --stat 2>/dev/null)

  _pr_title_prompt="Generate a GitHub pull request title for these commits.
Reply with ONLY the title on one line. No explanation. No backticks. No quotes. No trailing period.
Format: type(scope): short description
Rules:
- type: feat fix refactor style docs test chore perf
- scope: single word, most specific component changed
- description: imperative mood, HARD LIMIT 50 chars after the colon
- Total title MUST be under 72 characters. Count carefully.
- BAD: \"feat(glitchbridge): add authentication flow to glitchbridge electron app server\"
- GOOD: \"feat(glitchbridge): add auth flow to electron server\"

Branch: $CURRENT_BRANCH
Commits:
$PR_COMMITS"

  _pr_body_prompt="Generate a GitHub pull request body in markdown.
Use this exact structure — fill every section with real content, no placeholders:

## What and why
2-3 sentences explaining: what problem or limitation existed before this PR, why it occurred (root cause), and what this PR does to fix or add it. Name the specific files, functions, or behaviors involved.

## Changes
$PR_DIFF_STAT

## Test plan
- [ ] Write specific, actionable test steps based on what actually changed. Not generic steps.

Reply with ONLY the markdown. No preamble. No backticks around the whole response.

Branch: $CURRENT_BRANCH
Commits:
$PR_COMMITS"

  echo "→ Generating PR title…"
  _title_escaped=$(python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" <<< "$_pr_title_prompt")
  PR_TITLE=$(curl -s --connect-timeout 10 "$OLLAMA_URL" \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"$MODEL\",\"prompt\":$_title_escaped,\"stream\":false}" \
    | python3 -c "
import sys, json
try:
  d = json.load(sys.stdin)
  msg = d.get('response', '').strip()
  lines = [l.strip() for l in msg.splitlines() if l.strip()]
  title = lines[0] if lines else ''
  # Hard truncate at word boundary if model ignores the 72-char instruction.
  if len(title) > 72:
    title = title[:72].rsplit(' ', 1)[0].rstrip(',:;-')
  print(title)
except Exception:
  pass
" || true)

  if [[ -z "$PR_TITLE" ]]; then
    PR_TITLE="feat(${CURRENT_BRANCH}): changes from branch"
  fi

  echo "→ Generating PR body…"
  _body_escaped=$(python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" <<< "$_pr_body_prompt")
  PR_BODY=$(curl -s --connect-timeout 10 "$OLLAMA_URL" \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"$MODEL\",\"prompt\":$_body_escaped,\"stream\":false}" \
    | python3 -c "
import sys, json
try:
  d = json.load(sys.stdin)
  print(d.get('response', '').strip())
except Exception:
  pass
" || true)

  if [[ -z "$PR_BODY" ]]; then
    _pr_bullets=""
    while IFS= read -r _line; do
      _pr_bullets+="- ${_line}"$'\n'
    done <<< "$PR_COMMITS"
    PR_BODY="## What and why
${_pr_bullets}
## Changes
$PR_DIFF_STAT"
  fi

  echo "→ Pushing branch '$CURRENT_BRANCH'…"
  git push -u origin "$CURRENT_BRANCH"

  echo "→ Creating PR…"
  PR_URL=$(gh pr create \
    --base "$BASE_BRANCH" \
    --assignee @me \
    --title "$PR_TITLE" \
    --body "$PR_BODY")

  echo ""
  echo "✓ PR created: $PR_URL"
  echo "  Branch: $CURRENT_BRANCH → $BASE_BRANCH"
  echo "  Title:  $PR_TITLE"
  exit 0
fi

# ── paused check ─────────────────────────────────────────────────────────────

if [[ -f "$HOME/.gai/paused" ]]; then
  echo "⏸  Auto-commit paused (gai pause). Run 'gai resume' to re-enable." >&2
  exit 0
fi

# ── logging setup ────────────────────────────────────────────────────────────

_prune_logs
LOG_FILE="$LOG_DIR/$(date +%Y-%m-%d).log"
exec > >(tee -a "$LOG_FILE") 2>&1
echo "── gai $(date '+%Y-%m-%d %H:%M:%S') ──────────────────────────────────────────"

# ── sanity checks ────────────────────────────────────────────────────────────

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "error: not inside a git repository" >&2
  exit 1
fi

if ! curl -s --connect-timeout 2 "http://localhost:11434" > /dev/null 2>&1; then
  echo "error: Ollama not running." >&2
  echo "  Start:   ollama serve" >&2
  echo "  Install: brew install ollama && ollama pull $MODEL" >&2
  exit 1
fi

# ── ensure gai-watch is running in this repo ─────────────────────────────────

_ensure_watch() {
  local repo repo_hash pidfile pid
  repo=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  repo_hash=$(echo "$repo" | md5)
  pidfile="/tmp/gai-watch-${repo_hash}.pid"
  if [[ -f "$pidfile" ]]; then
    pid=$(awk '{print $1}' "$pidfile" 2>/dev/null)
    kill -0 "$pid" 2>/dev/null && return 0
    rm -f "$pidfile"
  fi
  gai-watch > "/tmp/gai-watch-${repo_hash}.log" 2>&1 &
  disown $! 2>/dev/null || true
  echo "$! $repo" > "$pidfile"
}

_ensure_watch

# ── per-repo lock (prevent concurrent gai runs racing on .git/index.lock) ─────
# macOS has no flock; use an atomic mkdir mutex with stale-lock reclaim.

GAI_LOCK_DIR=""

_release_lock() {
  if [[ -n "$GAI_LOCK_DIR" ]]; then
    rm -rf "$GAI_LOCK_DIR" 2>/dev/null || true
  fi
}

_acquire_lock() {
  local repo repo_hash
  repo=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  repo_hash=$(echo "$repo" | md5)
  GAI_LOCK_DIR="/tmp/gai-run-${repo_hash}.lock"

  if mkdir "$GAI_LOCK_DIR" 2>/dev/null; then
    echo $$ > "$GAI_LOCK_DIR/pid"
    trap _release_lock EXIT INT TERM
    return 0
  fi

  # Lock exists — reclaim only if the owning process is dead.
  local owner
  owner=$(cat "$GAI_LOCK_DIR/pid" 2>/dev/null || true)
  if [[ -n "$owner" ]] && kill -0 "$owner" 2>/dev/null; then
    echo "Another gai is already running for this repo (pid $owner) — skipping."
    GAI_LOCK_DIR=""
    exit 0
  fi

  rm -rf "$GAI_LOCK_DIR" 2>/dev/null || true
  if mkdir "$GAI_LOCK_DIR" 2>/dev/null; then
    echo $$ > "$GAI_LOCK_DIR/pid"
    trap _release_lock EXIT INT TERM
    return 0
  fi

  echo "Could not acquire gai lock for this repo — skipping."
  GAI_LOCK_DIR=""
  exit 0
}

_acquire_lock

# ── helpers ──────────────────────────────────────────────────────────────────

is_secret() {
  local f="$1"
  [[ "$f" == *".env"* || "$f" == *"credentials"* || "$f" == *"secret"* || \
     "$f" == *".key"  || "$f" == *"id_rsa"*       || "$f" == *"id_ed25519"* ]]
}

# Deterministic short scope derived from a file path — used both as a prompt
# hint (small models copy raw paths verbatim if asked to "derive" one) and as
# a fallback when the model's own scope is unusable (contains "/", too long).
_short_scope() {
  local file="$1" base dir
  base=$(basename "$file")
  base="${base%.*}"
  case "$base" in
    index|route|page|actions|action|schema|schemas|types|utils|hooks|constants|config|page.tsx)
      dir=$(dirname "$file")
      base=$(basename "$dir")
      ;;
  esac
  base=$(echo "$base" | sed -E 's/\[[^]]*\]//g')
  base=$(echo "$base" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g' | sed -E 's/^-+|-+$//g')
  [[ -z "$base" ]] && base="repo"
  echo "$base"
}

gen_message() {
  local file="$1" diff="$2"
  local suggested_scope
  suggested_scope=$(_short_scope "$file")
  local prompt="Write a git commit message in conventional commit format for this diff.
Reply with ONLY the commit message on one line. No explanation. No backticks. No quotes.

Format: type(scope): short description
Rules:
- type: feat fix refactor style docs test chore perf
- scope: ONE short word or hyphenated component name, 1-3 words, NO slashes, NO file extensions, NOT the raw file path. Suggested scope for this file: $suggested_scope — use it unless a shorter/more accurate component name is obvious from the diff.
- description: imperative mood, max 72 chars, describe the ACTUAL change in THIS diff — never a generic phrase like \"update logic\" or \"update index watching logic\"
- describe WHY the change was needed or what problem it solves, not just what file changed
- example of the format only (do not reuse this wording): \"fix(auth): stop clearing session on token refresh\"

File: $file
Diff:
$diff"

  local escaped
  escaped=$(python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" <<< "$prompt")

  local response
  response=$(curl -s --connect-timeout 10 "$OLLAMA_URL" \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"$MODEL\",\"prompt\":$escaped,\"stream\":false}")

  local msg
  msg=$(python3 -c "
import sys, json
try:
  d = json.load(sys.stdin)
  msg = d.get('response', '').strip()
  lines = [l.strip() for l in msg.splitlines() if l.strip()]
  print(lines[0] if lines else '')
except Exception:
  pass
" <<< "$response" || true)

  _sanitize_message "$msg" "$file" "$suggested_scope"
}

# Guards against two small-model failure modes seen in practice:
#  1. scope echoes the raw file path instead of a short component name
#  2. on a low-signal diff (e.g. a one-line config bump) the model parrots
#     boilerplate like "update index watching logic" instead of describing
#     the actual change
_sanitize_message() {
  local msg="$1" file="$2" fallback_scope="$3"

  if [[ -z "$msg" ]]; then
    echo ""
    return
  fi

  local re='^([a-z]+)\((.*)\):[[:space:]]*(.*)$'
  if [[ "$msg" =~ $re ]]; then
    local type="${BASH_REMATCH[1]}" scope="${BASH_REMATCH[2]}" desc="${BASH_REMATCH[3]}"

    if [[ "$scope" == *"/"* || ${#scope} -gt 24 ]]; then
      scope="$fallback_scope"
    fi

    case "$desc" in
      *"index watching logic"*|*"update logic"*|"update index watching"*)
        desc="update $(basename "$file")"
        ;;
    esac

    echo "${type}(${scope}): ${desc}"
  else
    echo "$msg"
  fi
}

commit_file() {
  local file="$1"

  if is_secret "$file"; then
    echo "  ⚠ skip (secret): $file"
    return 1
  fi

  echo ""
  echo "── $file"

  local diff
  diff=$(git diff --cached -- "$file")
  if [[ -z "$diff" ]]; then
    echo "  (empty staged diff — skipping)"
    return 1
  fi

  local msg
  msg=$(gen_message "$file" "$diff")
  if [[ -z "$msg" ]]; then
    echo "  ✗ model returned empty message — skipping"
    return 1
  fi

  echo "  → $msg"

  if $DRY_RUN; then
    echo "  (dry-run)"
  else
    git commit --no-verify -m "$msg"
  fi
  return 0
}

# ── staged mode (default) ────────────────────────────────────────────────────

if [[ "$MODE" == "staged" ]]; then
  FILES=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && FILES+=("$line")
  done < <(git diff --cached --name-only)

  if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "No staged files. Stage files with 'git add', or use --all for all dirty files."
    exit 0
  fi

  echo "Staged: ${#FILES[@]} file(s) → committing one by one…"

  # Unstage everything, then re-add one file at a time below.
  # NEVER fall back to anything that empties the index (e.g. git rm --cached -r .):
  # on failure that turns the next per-file commit into a mass-deletion of history.
  if ! git reset -q; then
    echo "error: 'git reset' failed — .git/index.lock is held by another git process." >&2
    echo "  Aborting to avoid rewriting history. Retry once the other process finishes." >&2
    exit 1
  fi

  COMMITTED=0 SKIPPED=()
  for FILE in "${FILES[@]}"; do
    git add -- "$FILE"
    if commit_file "$FILE"; then
      COMMITTED=$((COMMITTED + 1))
    else
      git reset HEAD -- "$FILE" > /dev/null 2>&1 || true
      SKIPPED+=("$FILE")
    fi
  done

# ── all mode ─────────────────────────────────────────────────────────────────

else
  FILES=()
  while IFS= read -r line; do
    local_file=$(echo "$line" | awk '{print $2}')
    [[ -n "$local_file" ]] && FILES+=("$local_file")
  done < <(git status --short)

  if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "Working tree is clean. Nothing to commit."
    exit 0
  fi

  echo "Dirty: ${#FILES[@]} file(s) → committing one by one…"

  COMMITTED=0 SKIPPED=()
  for FILE in "${FILES[@]}"; do
    if is_secret "$FILE"; then
      echo "  ⚠ skip (secret): $FILE"
      SKIPPED+=("$FILE")
      continue
    fi

    local_status=$(git status --short -- "$FILE" | awk '{print $1}')
    local_diff=""
    if [[ "$local_status" == "??" ]]; then
      local_diff=$(git diff --no-index /dev/null "$FILE" 2>/dev/null || true)
    else
      local_diff=$(git diff -- "$FILE")
    fi
    [[ -z "$local_diff" ]] && continue

    git add -- "$FILE"
    if commit_file "$FILE"; then
      COMMITTED=$((COMMITTED + 1))
    else
      git reset HEAD -- "$FILE" > /dev/null 2>&1 || true
      SKIPPED+=("$FILE")
    fi
  done
fi

# ── summary ──────────────────────────────────────────────────────────────────

echo ""
echo "Committed: $COMMITTED file(s)."
if [[ ${#SKIPPED[@]} -gt 0 ]]; then
  echo "Skipped (${#SKIPPED[@]}):"
  for f in "${SKIPPED[@]}"; do echo "  - $f"; done
fi
